# =============================================================================
# digital-guide-ai 后端环境变量模板
# 用法：复制为 backend/.env 并填写真实值
#   cp backend/.env.example backend/.env
#   然后编辑 backend/.env
# 注意：.env 已被 .gitignore 忽略，不会提交密钥
# =============================================================================

# ─── LLM（DeepSeek，兼容 OpenAI 协议）──────────────────────────────────────
LLM_API_KEY=sk-在此填入你的DeepSeek密钥
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-v4-flash

# ─── JWT 认证 ─────────────────────────────────────────────────────────────
# 用任意长随机字符串生成： openssl rand -hex 32
JWT_SECRET_KEY=请改成你自己的随机字符串至少32位

# ─── CosyVoice TTS（仅 TTS/语音对话需要）──────────────────────────────────
# CosyVoice 仓库根目录（git clone 出来的本地路径，含 third_party/Matcha-TTS）
COSYVOICE_DIR=/home/yourname/CosyVoice
COSYVOICE_MATCHA_DIR=/home/yourname/CosyVoice/third_party/Matcha-TTS
# 实际加载的预训练模型目录
COSYVOICE_MODEL_DIR=/home/yourname/CosyVoice/pretrained_models/CosyVoice-300M-SFT
# 说话人音色
TTS_SPEAKER=中文女

# ─── LiveTalking 数字人服务（仅数字人功能需要）────────────────────────────
# 默认与本机 LiveTalking 服务同部署
LIVETALKING_BASE_URL=http://localhost:8010

# ─── 可选项 ───────────────────────────────────────────────────────────────
# 日志级别（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO
# HuggingFace 国内镜像（下载嵌入模型时加速）
HF_ENDPOINT=https://hf-mirror.com